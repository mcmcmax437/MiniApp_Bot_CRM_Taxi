# ---------------------------------------------------------------------------
# Taxi Rental Mini App - environment configuration
# Copy this file to ".env" and fill in the values.
# ---------------------------------------------------------------------------

# --- Telegram ---------------------------------------------------------------
# Get this from @BotFather (/newbot). Keep it secret.
BOT_TOKEN=123456:replace-with-your-bot-token

# Your own Telegram numeric user id. This account becomes the super-admin
# that can activate / suspend other car owners. Use the bot command /id to find it.
TELEGRAM_SUPERADMIN_ID=000000000

# Public HTTPS URL where the Mini App is served (used by the bot's "Open app" button
# and as the web_app URL). In production this is your domain, e.g. https://taxi.example.com
PUBLIC_URL=https://taxi.example.com

# Bare domain (host only) that Caddy uses to provision an HTTPS certificate.
# Use "localhost" for local testing without TLS.
DOMAIN=taxi.example.com

# --- Database ---------------------------------------------------------------
POSTGRES_USER=taxi
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=taxi
# Host: localhost for npm run dev | db for docker-compose
POSTGRES_HOST=localhost
LOCAL_DB_PORT=5432
# Optional — if omitted, npm scripts and the API build this automatically from the values above.
# DATABASE_URL=postgresql://taxi:change-me-strong-password@localhost:5432/taxi?schema=public

# --- API --------------------------------------------------------------------
API_PORT=3000
# Comma-separated list of allowed origins for CORS in development.
CORS_ORIGINS=http://localhost:5173
# Set to "true" to run the reminder scheduler inside the API process.
RUN_SCHEDULER=true
# How many days before insurance / inspection expiry to start reminding.
REMINDER_DAYS_BEFORE=7
# Cron expression for the daily reminder job (default: 09:00 every day).
REMINDER_CRON=0 9 * * *

# --- Local dev convenience (do NOT use in production) -----------------------
# When true (and NODE_ENV != production), the API authenticates as a fake ACTIVE
# super-admin if no Telegram initData is present, so you can open the Mini App in a
# normal browser at http://localhost:5173 without Telegram. Ignored in production.
DEV_BYPASS_AUTH=false
DEV_USER_ID=999999999

# --- Mini App (build-time) --------------------------------------------------
# Base path for API calls from the Mini App. Same-origin "/api" in production.
VITE_API_BASE=/api

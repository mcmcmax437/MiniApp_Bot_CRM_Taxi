# Rendered on the VPS by scripts/deploy-vps.mjs (DOMAIN and APP_DIR substituted).
# Serves the Mini App SPA and proxies /api to the Fastify process.

server {
    listen 80;
    listen [::]:80;
    server_name __DOMAIN__;

    client_max_body_size 20M;

    # API + uploaded media (documents, HEIC, PDF). Do not buffer large files on disk.
    location /api/ {
        client_max_body_size 20M;
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_pass_header Content-Type;
        proxy_pass_header Content-Disposition;
        proxy_pass_header Cache-Control;
    }

    location /health {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    root __APP_DIR__/apps/miniapp/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

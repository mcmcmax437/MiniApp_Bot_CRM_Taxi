{
  "name": "@taxi/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "node scripts/run-prisma.mjs generate",
    "prisma:migrate": "node scripts/run-prisma.mjs migrate dev",
    "prisma:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "db:sync": "node scripts/sync-schema.mjs",
    "db:auth-help": "node scripts/print-mysql-auth-fix.mjs",
    "db:drop": "node scripts/drop-database.mjs",
    "db:push": "node scripts/run-prisma.mjs db push --skip-generate",
    "db:push:env": "node scripts/run-prisma.mjs db push --skip-generate",
    "dev:db": "node scripts/dev-db.mjs",
    "seed": "node scripts/run-with-env.mjs npx tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.4",
    "@prisma/client": "^6.2.1",
    "@taxi/shared": "*",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

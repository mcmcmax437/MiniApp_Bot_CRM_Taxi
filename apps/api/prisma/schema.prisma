// Prisma schema for the Taxi Rental Mini App (multi-tenant SaaS).
// Every domain table carries `ownerId` and is always queried scoped to the
// authenticated owner (tenant).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OwnerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum CarStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  INACTIVE
}

enum DriverStatus {
  ACTIVE
  INACTIVE
}

enum RentPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum AgreementStatus {
  ACTIVE
  ENDED
}

enum PaymentMethod {
  CASH
  BANK
  CARD
  OTHER
}

enum PaymentType {
  RENT
  DEPOSIT
  REFUND
  FINE
}

enum ExpenseCategory {
  MAINTENANCE
  REPAIR
  INSURANCE
  FUEL
  TAX
  OTHER
}

enum FineStatus {
  UNPAID
  PAID
}

enum DocumentRelatedType {
  CAR
  DRIVER
  AGREEMENT
}

enum MaintenanceIntervalKind {
  DAYS
  MONTHS
  MILEAGE
  YEARLY
}

enum MileageSource {
  MANUAL
  WEEKLY
  MAINTENANCE
}

enum TireSeason {
  SUMMER
  WINTER
  ALL_SEASON
}

model Owner {
  id                    String      @id @default(cuid())
  telegramUserId        BigInt      @unique
  name                  String?
  username              String?
  status                OwnerStatus @default(PENDING)
  locale                String      @default("uk")
  currency              String      @default("UAH")
  subscriptionExpiresAt DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  cars       Car[]
  drivers    Driver[]
  agreements RentalAgreement[]
  payments   Payment[]
  expenses   Expense[]
  fines      Fine[]
  shifts              Shift[]
  documents           Document[]
  reminderSettings    OwnerReminderSettings?
  carDocuments        CarDocument[]
  maintenanceRules    MaintenanceRule[]
  maintenanceRecords  MaintenanceRecord[]
  mileageLogs         MileageLog[]
}

model Car {
  id               String     @id @default(cuid())
  ownerId          String
  owner            Owner      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  plate            String
  vin              String?
  make             String?
  model            String?
  year             Int?
  trackerLogin     String?
  trackerPassword  String?
  trackerUrl       String?
  trackerNotes     String?    @db.VarChar(2000)
  status           CarStatus  @default(AVAILABLE)
  insuranceExpiry  DateTime?
  inspectionExpiry DateTime?
  notes            String?
  coverDocumentId  String?
  currentMileage   Int?
  mileageUpdatedAt DateTime?
  purchasePrice    Float?
  purchaseDate     DateTime?
  tireBrand        String?
  tireSize         String?
  tireSeason       TireSeason?
  tireInstalledAt  DateTime?
  tireNotes        String?    @db.VarChar(2000)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  agreements         RentalAgreement[]
  payments           Payment[]
  expenses           Expense[]
  fines              Fine[]
  shifts             Shift[]
  documents          CarDocument[]
  maintenanceRules   MaintenanceRule[]
  maintenanceRecords MaintenanceRecord[]
  mileageLogs        MileageLog[]

  @@index([ownerId])
  @@index([ownerId, status])
}

model OwnerReminderSettings {
  id                    String  @id @default(cuid())
  ownerId               String  @unique
  owner                 Owner   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  insuranceDaysBefore   String  @default("14,7,3")
  inspectionDaysBefore  String  @default("7,3,1")
  documentDaysBefore    String  @default("14,7,3")
  maintenanceDaysBefore String  @default("7,3,1")
  weeklyMileageEnabled  Boolean @default(true)
  weeklyMileageWeekday  Int     @default(1)
  updatedAt             DateTime @updatedAt
}

model CarDocument {
  id         String   @id @default(cuid())
  ownerId    String
  owner      Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId      String
  car        Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  title      String
  expiryDate DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ownerId])
  @@index([carId])
}

model MaintenanceRule {
  id                   String                  @id @default(cuid())
  ownerId              String
  owner                Owner                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId                String
  car                  Car                     @relation(fields: [carId], references: [id], onDelete: Cascade)
  name                 String
  presetKey            String?
  description          String?
  intervalKind         MaintenanceIntervalKind
  intervalValue        Int
  yearlyMonth          Int?
  isMandatory          Boolean                 @default(true)
  isActive             Boolean                 @default(true)
  lastCompletedAt      DateTime?
  lastCompletedMileage Int?
  nextDueDate          DateTime?
  nextDueMileage       Int?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  records              MaintenanceRecord[]

  @@index([ownerId])
  @@index([carId])
}

model MaintenanceRecord {
  id          String           @id @default(cuid())
  ownerId     String
  owner       Owner            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId       String
  car         Car              @relation(fields: [carId], references: [id], onDelete: Cascade)
  ruleId      String?
  rule        MaintenanceRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  title       String
  presetKey   String?
  completedAt DateTime
  mileageAt   Int?
  cost        Float?
  notes       String?
  createdAt   DateTime         @default(now())

  @@index([ownerId])
  @@index([carId])
  @@index([ruleId])
}

model MileageLog {
  id         String        @id @default(cuid())
  ownerId    String
  owner      Owner         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId      String
  car        Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  driverId   String?
  odometer   Int
  recordedAt DateTime
  source     MileageSource @default(MANUAL)
  note       String?
  createdAt  DateTime      @default(now())

  @@index([ownerId])
  @@index([carId, recordedAt])
}

model Driver {
  id               String       @id @default(cuid())
  ownerId          String
  owner            Owner        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  fullName         String
  phone            String?
  telegramUsername String?
  pesel            String?
  passportNumber   String?
  addressCity      String?
  addressPostalCode String?
  addressStreet    String?
  addressHouse     String?
  addressFlat      String?
  fatherName       String?
  motherName       String?
  status           DriverStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  agreements RentalAgreement[]
  payments   Payment[]
  fines      Fine[]
  shifts     Shift[]

  @@index([ownerId])
  @@index([ownerId, status])
}

model RentalAgreement {
  id         String          @id @default(cuid())
  ownerId    String
  owner      Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId      String
  car        Car             @relation(fields: [carId], references: [id], onDelete: Cascade)
  driverId   String
  driver     Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  rentAmount    Float
  depositAmount Float           @default(0)
  period        RentPeriod      @default(DAILY)
  startDate  DateTime
  endDate    DateTime?
  status     AgreementStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([driverId])
  @@index([carId])
}

model Payment {
  id        String        @id @default(cuid())
  ownerId   String
  owner     Owner         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  carId     String?
  car       Car?          @relation(fields: [carId], references: [id], onDelete: SetNull)
  amount    Float
  date      DateTime
  method    PaymentMethod @default(CASH)
  type      PaymentType   @default(RENT)
  note      String?
  createdAt DateTime      @default(now())

  @@index([ownerId])
  @@index([ownerId, date])
  @@index([driverId])
}

model Expense {
  id        String          @id @default(cuid())
  ownerId   String
  owner     Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId     String?
  car       Car?            @relation(fields: [carId], references: [id], onDelete: SetNull)
  category  ExpenseCategory @default(OTHER)
  amount    Float
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())

  @@index([ownerId])
  @@index([ownerId, date])
  @@index([carId])
}

model Fine {
  id          String     @id @default(cuid())
  ownerId     String
  owner       Owner      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId       String?
  car         Car?       @relation(fields: [carId], references: [id], onDelete: SetNull)
  driverId    String?
  driver      Driver?    @relation(fields: [driverId], references: [id], onDelete: SetNull)
  amount      Float
  date        DateTime
  status      FineStatus @default(UNPAID)
  description String?
  createdAt   DateTime   @default(now())

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([driverId])
}

model Shift {
  id           String   @id @default(cuid())
  ownerId      String
  owner        Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  carId        String
  car          Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  driverId     String
  driver       Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  date         DateTime
  mileageStart Int?
  mileageEnd   Int?
  income       Float?
  note         String?
  createdAt    DateTime @default(now())

  @@index([ownerId])
  @@index([ownerId, date])
}

model Document {
  id          String              @id @default(cuid())
  ownerId     String
  owner       Owner               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  relatedType DocumentRelatedType
  relatedId   String
  fileName    String
  filePath    String
  mimeType    String?
  isCarPhoto  Boolean             @default(false)
  displayName String?
  notes       String?             @db.Text
  uploadedAt  DateTime            @default(now())

  @@index([ownerId])
  @@index([ownerId, relatedType, relatedId])
}
